# Application
APP_NAME=predictive-ml-models
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30

# Model Configuration
HEALTH_MODEL_PATH=models/health_model.pkl
STOCK_MODEL_PATH=models/stock_model.pkl
EXPLAINER_CACHE=true
BATCH_SIZE=32

# Data Paths
DATA_PATH=data/
SAMPLE_DATA_PATH=data/sample/
LOGS_PATH=logs/

# Monitoring & Drift Detection
DRIFT_DETECTION_ENABLED=true
DRIFT_ALERT_THRESHOLD=0.15
DATA_DRIFT_CHECK_INTERVAL=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOGGING=true

# Security & Privacy
PII_MASKING=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Explainability
SHAP_ENABLED=true
SHAP_BACKGROUND_SAMPLES=100
LIME_ENABLED=true
LIME_SAMPLES=50

# Database (if using)
DATABASE_URL=sqlite:///./predictions.db
DB_ECHO=false

# External Services
SLACK_WEBHOOK_URL=
EMAIL_ALERTS_ENABLED=false
EMAIL_SMTP_SERVER=
EMAIL_ALERT_RECIPIENTS=

# Hyperparameter Optimization
OPTUNA_TRIALS=100
OPTUNA_TIMEOUT=3600
CROSS_VALIDATION_FOLDS=5

# Stock Market Data
STOCK_DATA_SOURCE=yfinance
STOCK_LOOKBACK_WINDOW=60
STOCK_FORECAST_HORIZON=30

# Healthcare Specific
HIPAA_COMPLIANCE=true
PATIENT_DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=2555
