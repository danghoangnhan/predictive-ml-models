# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Model Configuration
HEALTHCARE_MODEL_PATH=models/healthcare_ensemble.pkl
FINANCE_MODEL_PATH=models/finance_xgboost.pkl

# Data Configuration
DATA_PATH=data/
SAMPLE_DATA_PATH=data/sample/

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring
DRIFT_DETECTION_ENABLED=true
RETRAINING_TRIGGER_ENABLED=true

# Database (if used)
DATABASE_URL=sqlite:///./predictions.db

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# Environment
ENVIRONMENT=development  # development, staging, production
